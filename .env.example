APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000
WHATSAPP_NUMBER=
APP_FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file


BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_API_LEVEL=info
LOG_PAYMENTS_LEVEL=info
LOG_WEBHOOKS_LEVEL=info
LOG_EMAILS_LEVEL=info

DB_CONNECTION=sqlite
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
PUBLIC_RESPONSE_CACHE_SECONDS=300
REPORT_CACHE_SECONDS=120
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_PUBLIC_SUBMIT_PER_MINUTE=10
RATE_LIMIT_PUBLIC_READ_PER_MINUTE=120
RATE_LIMIT_ADMIN_PER_MINUTE=300
RATE_LIMIT_UPLOADS_PER_MINUTE=20
MAX_UPLOAD_KB=5120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

TABBY_PUBLIC_KEY=
TABBY_SECRET_KEY=
TABBY_MERCHANT_CODE=
TABBY_WEBHOOK_SECRET=

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0

HORIZON_ENABLED=false
HORIZON_DOMAIN=
HORIZON_PATH=horizon

BACKUP_ENABLED=false
BACKUP_DISK=local
BACKUP_DB_CONNECTION="${DB_CONNECTION}"
BACKUP_DB_PREFIX=visatko-db
BACKUP_STORAGE_PATHS=storage/app
BACKUP_RETENTION_DAYS=14

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
